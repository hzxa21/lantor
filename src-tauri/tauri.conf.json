{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lantor",
  "version": "0.1.0",
  "identifier": "app.lantor.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lantor",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "visible": false,
        "dragDropEnabled": false
      },
      {
        "label": "splashscreen",
        "title": "Lantor",
        "url": "splashscreen.html",
        "width": 520,
        "height": 520,
        "center": true,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Library/Application Support/Lantor/attachments/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

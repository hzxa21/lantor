# Lantor creates this SQLite database automatically on first start.
# Default: sqlite://~/Library/Application Support/Lantor/lantor.sqlite
# LANTOR_DATABASE_URL=sqlite://~/Library/Application Support/Lantor/lantor.sqlite
# `DATABASE_URL` is honored as a fallback only when it is also a sqlite: URL.

# Override where copied message attachments are stored.
# Default: ~/Library/Application Support/Lantor/attachments
# LANTOR_ATTACHMENT_DIR=/Users/you/Library/Application Support/Lantor/attachments

# Browser/Tailscale access defaults to 0.0.0.0:8787. Override to 127.0.0.1:8787
# to keep it loopback-only, or set to "off" / "none" to disable the web server.
# LANTOR_WEB_BIND=0.0.0.0:8787

# Optional 6-digit PIN gate for browser access. Set this before exposing the
# web UI outside the local machine. After too many bad PINs, unlock from the
# host with the sqlite3 command shown on the login page.
# LANTOR_WEB_PIN=123456
# LANTOR_WEB_PIN_MAX_FAILURES=10

# Base URL used when Lantor generates web links. If unset, Lantor derives a
# local URL from LANTOR_WEB_BIND.
# LANTOR_WEB_PUBLIC_URL=http://127.0.0.1:8787

# Override the static web bundle served by the desktop process.
# Default: auto-detect dist/ next to the repo or current working directory.
# LANTOR_WEB_DIST=/absolute/path/to/dist

# Rotate warm Codex sessions after the latest stopped run exceeds this many
# input tokens. Values below 50000 are ignored.
# LANTOR_CODEX_CONTEXT_ROTATE_INPUT_TOKENS=180000
